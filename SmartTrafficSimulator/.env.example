# Host ports exposed by Docker Compose.
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Public WebSocket URL used by the browser.
# Keep this port synchronized with BACKEND_PORT.
TRAFFIC_WS_URL=ws://localhost:8000/ws/traffic

# Public HTTP API URL used by the browser for violation history.
# Keep this port synchronized with BACKEND_PORT.
TRAFFIC_API_URL=http://localhost:8000

# --- Tích hợp hub STMS (tùy chọn) ---
# Bật để chuyển tiếp vi phạm của simulator lên hub trung tâm. Bỏ trống = chạy độc lập.
# HUB_URL=http://localhost:8000
# HUB_DEVICE_KEY=dev-ingest-key-change-me
