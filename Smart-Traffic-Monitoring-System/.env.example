# File này chỉ dùng cho docker-compose.yml (biến ${...} và build-args).
# Copy thành ".env" ở cùng cấp với docker-compose.yml khi deploy.
# Giá trị thực tế của app (JWT, GROQ_API_KEY, BOT_TOKEN...) nằm ở backend/app/.env

# Domain public trỏ vào VPS (DNS A record). Để "localhost" nếu chạy dev không domain.
DOMAIN=localhost

# URL public để frontend build biết gọi API ở đâu, và backend redirect "/" đúng chỗ.
# Deploy: đổi thành https://yourdomain.com
PUBLIC_API_URL=http://localhost:8000
PUBLIC_API_WS_URL=ws://localhost:8000
PUBLIC_FRONTEND_URL=http://localhost:5173

# Phải khớp với DATABASE_USERNAME/PASSWORD/NAME trong backend/app/.env
# (Postgres image yêu cầu đúng tên biến POSTGRES_USER/PASSWORD/DB)
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=odoo
DATABASE_NAME=transportation_system
